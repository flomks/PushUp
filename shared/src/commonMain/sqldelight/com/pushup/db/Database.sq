deletePushUpRecord:
DELETE FROM PushUpRecord
WHERE id = ?;

selectPushUpRecordsBySessionId:
SELECT *
FROM PushUpRecord
WHERE sessionId = ?
ORDER BY timestamp ASC;

countPushUpRecordsBySessionId:
SELECT COUNT(*)
FROM PushUpRecord
WHERE sessionId = ?;

deletePushUpRecordsBySessionId:
DELETE FROM PushUpRecord
WHERE sessionId = ?;

