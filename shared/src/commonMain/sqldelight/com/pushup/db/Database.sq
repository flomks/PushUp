insertTimeCredit:
INSERT INTO TimeCredit (id, userId, totalEarnedSeconds, totalSpentSeconds, dailyEarnedSeconds, dailySpentSeconds, lastResetAt, lastUpdatedAt, syncStatus)
VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?);

selectTimeCreditById:
