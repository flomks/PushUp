updateTimeCredit:
UPDATE TimeCredit
SET totalEarnedSeconds = ?, totalSpentSeconds = ?, dailyEarnedSeconds = ?, dailySpentSeconds = ?, lastResetAt = ?, lastUpdatedAt = ?, syncStatus = ?
WHERE id = ?;

deleteTimeCredit:
DELETE FROM TimeCredit
WHERE id = ?;

deleteTimeCreditByUserId:
DELETE FROM TimeCredit
WHERE userId = ?;

selectTimeCreditByUserId:
SELECT *
FROM TimeCredit
WHERE userId = ?;

upsertTimeCredit:
INSERT OR REPLACE INTO TimeCredit (id, userId, totalEarnedSeconds, totalSpentSeconds, dailyEarnedSeconds, dailySpentSeconds, lastResetAt, lastUpdatedAt, syncStatus)
VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?);

-- =============================================================================
-- UserSettings Queries
