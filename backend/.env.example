# =============================================================================
# PushUp Backend -- Environment Variables
# =============================================================================
# Copy this file to /opt/pushup/.env on your root server and fill in the
# real values. NEVER commit .env to version control.
#
# On the root server the file lives at /opt/pushup/.env and is loaded by
# docker-compose.yml automatically.
# =============================================================================


# -----------------------------------------------------------------------------
# Supabase -- JWT verification (server-side)
# -----------------------------------------------------------------------------
#
# Supabase changed its JWT signing strategy in 2024/2025:
#
#   NEW projects (created 2025+):
#     - JWTs are signed with RSA (RS256, asymmetric)
#     - Public keys are published at <SUPABASE_URL>/auth/v1/.well-known/jwks.json
#     - Set SUPABASE_URL below -- the backend fetches keys automatically
#     - SUPABASE_JWT_SECRET is NOT needed and can be left unset
#
#   LEGACY projects (created before 2025):
#     - JWTs are signed with HMAC-SHA256 (HS256, symmetric shared secret)
#     - Set SUPABASE_JWT_SECRET below
#     - SUPABASE_URL is optional (only needed if you also use JWKS)
#
# The backend auto-detects the mode:
#   SUPABASE_URL set     -> JWKS / RS256 mode  (new projects)
#   SUPABASE_URL not set -> HS256 mode          (legacy projects)
#
# -----------------------------------------------------------------------------

# Supabase project URL -- used to build the JWKS endpoint URL for RS256 verification.
# Format: https://<your-project-ref>.supabase.co
# Required for NEW projects (RS256/JWKS). Optional for legacy projects.
SUPABASE_URL=https://<your-project-ref>.supabase.co

# JWT Secret -- only needed for LEGACY projects that still use HS256 signing.
# Found in: Supabase Dashboard > Settings > API > JWT Settings > JWT Secret
# Leave unset if your project uses RS256 (SUPABASE_URL is set instead).
# SUPABASE_JWT_SECRET=your-supabase-jwt-secret-here

# JWT Issuer -- the "iss" claim expected in every Supabase Access Token.
# Format: https://<your-project-ref>.supabase.co/auth/v1
JWT_ISSUER=https://<your-project-ref>.supabase.co/auth/v1


# -----------------------------------------------------------------------------
# Database Connection
# -----------------------------------------------------------------------------
# Full JDBC connection string for the Supabase PostgreSQL database.
#
# Format:
#   jdbc:postgresql://<host>:<port>/<database>?user=<user>&password=<password>&sslmode=require
#
# Where to find the values:
#   Supabase Dashboard > Settings > Database > Connection string > JDBC
#   (switch the toggle from "URI" to "JDBC" to get the jdbc:postgresql:// format)
DATABASE_URL=jdbc:postgresql://db.<your-project-ref>.supabase.co:5432/postgres?user=postgres&password=<your-db-password>&sslmode=require

# Connection-pool settings for the Ktor backend.
# Start conservatively on Supabase to avoid exhausting session-mode clients.
DB_MAX_POOL_SIZE=1
DB_MIN_IDLE=0
DB_CONNECTION_TIMEOUT_MS=3000


# -----------------------------------------------------------------------------
# Server Settings
# -----------------------------------------------------------------------------

# Port the Ktor server listens on (default: 8080)
PORT=8080

# Host/interface to bind to (default: 0.0.0.0 = all interfaces)
HOST=0.0.0.0

# Environment mode. Set to "production" to enforce strict env var checks.
KTOR_ENV=production

# Comma-separated list of allowed CORS hosts (without scheme).
# Example: CORS_ALLOWED_HOSTS=app.pushup.com,api.pushup.com
CORS_ALLOWED_HOSTS=


# -----------------------------------------------------------------------------
# Apple Push Notifications (APNs) -- Token-based auth (.p8 key)
# -----------------------------------------------------------------------------
#
# Required to send push notifications for friend requests and acceptances.
# If these are not set, pushes are silently skipped (app still works normally).
#
# How to get these values:
#   1. Apple Developer Portal -> Certificates, Identifiers & Profiles
#   2. Keys -> Create a new key -> enable "Apple Push Notifications service (APNs)"
#   3. Download the .p8 file (you can only download it ONCE -- keep it safe!)
#   4. Note the Key ID shown on the download page
#   5. Your Team ID is shown top-right in the Developer Portal (10 characters)
#
# -----------------------------------------------------------------------------

# 10-character Key ID from the Apple Developer Portal (shown when you create the key)
APNS_KEY_ID=XXXXXXXXXX

# 10-character Team ID from the Apple Developer Portal (top-right corner)
APNS_TEAM_ID=XXXXXXXXXX

# Contents of the downloaded .p8 file.
# Replace actual newlines with \n so it fits on one line.
# The header/footer lines must be included.
# Example:
#   APNS_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nMIGHAgEAMBMG...\n-----END PRIVATE KEY-----
APNS_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n<base64-encoded-key>\n-----END PRIVATE KEY-----

# Your app's bundle identifier (must match exactly what is in Xcode)
APNS_BUNDLE_ID=com.flomks.pushup

# Set to "true" for the production APNs endpoint (live App Store builds).
# Leave unset or set to anything else for the sandbox (development/TestFlight).
APNS_PRODUCTION=true
