# =============================================================================
# PushUp Backend -- Environment Variables
# =============================================================================
# Copy this file to .env and fill in the real values.
# NEVER commit .env to version control.
#
# Usage:
#   cp backend/.env.example backend/.env
#   # edit backend/.env with your actual values
#   # then start the server:
#   ./gradlew :backend:run
# =============================================================================


# -----------------------------------------------------------------------------
# Supabase -- Server-side credentials
# -----------------------------------------------------------------------------
# Found in: Supabase Dashboard > Settings > API

# JWT Secret used to verify incoming Supabase Access Tokens (HS256).
# Found in: Supabase Dashboard > Settings > API > JWT Settings > JWT Secret
# Keep this secret -- it allows verifying (and minting) arbitrary JWTs.
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-here

# JWT Issuer -- the "iss" claim expected in every Supabase Access Token.
# Format: https://<your-project-ref>.supabase.co/auth/v1
JWT_ISSUER=https://<your-project-ref>.supabase.co/auth/v1

# NOTE: SUPABASE_URL and SUPABASE_PUBLISHABLE_KEY are client-side values used by
# the mobile apps (iOS / Android) to talk to Supabase directly. The Ktor
# backend does NOT use them -- it only needs the JWT secret and DATABASE_URL.
# They are listed here for reference when setting up the full project.
#
# Supabase renamed "anon key" to "publishable key" in their new key design.
# Found in: Supabase Dashboard > Project Settings > API > Project API keys > publishable
#
# SUPABASE_URL=https://<your-project-ref>.supabase.co
# SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.<payload>.<signature>


# -----------------------------------------------------------------------------
# Database Connection
# -----------------------------------------------------------------------------
# Full JDBC connection string for the Supabase PostgreSQL database.
#
# Format:
#   jdbc:postgresql://<host>:<port>/<database>?user=<user>&password=<password>&sslmode=require
#
# Where to find the values:
#   Supabase Dashboard > Settings > Database > Connection string > JDBC
#   (switch the toggle from "URI" to "JDBC" to get the jdbc:postgresql:// format)
DATABASE_URL=jdbc:postgresql://db.<your-project-ref>.supabase.co:5432/postgres?user=postgres&password=<your-db-password>&sslmode=require


# -----------------------------------------------------------------------------
# Server Settings (optional -- defaults shown)
# -----------------------------------------------------------------------------

# Port the Ktor server listens on (default: 8080)
PORT=8080

# Host/interface to bind to (default: 0.0.0.0 = all interfaces)
HOST=0.0.0.0

# Environment mode. Set to "production" to enforce strict env var checks and
# disable development fallbacks (anyHost CORS, missing-secret warnings, etc.).
# Any other value (or unset) = development mode.
KTOR_ENV=development

# Comma-separated list of allowed CORS hosts (without scheme).
# In dev mode: http and https are both allowed for each host.
# In production mode: only https is allowed.
# Leave empty (or unset) to allow all origins -- only safe in development!
# Example: CORS_ALLOWED_HOSTS=app.pushup.com,api.pushup.com
CORS_ALLOWED_HOSTS=
