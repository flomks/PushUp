<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Performance: allow ProMotion displays to run at full 120 Hz -->
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>

	<!-- Camera permission description shown in the system prompt -->
	<key>NSCameraUsageDescription</key>
	<string>PushUp uses the camera to detect and count your push-ups in real time using pose estimation.</string>

	<!-- Motion & Fitness permission for vehicle detection during jogging (anti-cheat) -->
	<key>NSMotionUsageDescription</key>
	<string>PushUp uses motion activity to detect if you are in a vehicle during a run, ensuring distance is tracked fairly.</string>

	<!-- Location permission descriptions for jogging GPS tracking -->
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>PushUp uses your location to track your jogging route, distance, and pace during workouts.</string>
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>PushUp uses your location in the background to continue tracking your jogging route while the app is minimized.</string>

	<!-- Photo library permission (for avatar upload in Profile) -->
	<key>NSPhotoLibraryUsageDescription</key>
	<string>PushUp uses your photo library so you can set a profile picture.</string>

	<!-- App display name shown on the Home Screen and in Settings -->
	<key>CFBundleDisplayName</key>
	<string>PushUp</string>

	<!-- Supabase configuration — hardcoded here because xcconfig variable
	     injection into Info.plist is unreliable when GENERATE_INFOPLIST_FILE=YES.
	     The publishable key is intentionally public (client-side only). -->
	<key>SupabaseURL</key>
	<string>https://ptllenkizeipinpuqapl.supabase.co</string>

	<!-- Supabase publishable key (previously called "anon key").
	     Found in: Supabase Dashboard > Project Settings > API > Project API keys > publishable -->
	<key>SupabasePublishableKey</key>
	<string>eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InB0bGxlbmtpemVpcGlucHVxYXBsIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzMwNzAzNTksImV4cCI6MjA4ODY0NjM1OX0.yK-LoeQeEqkk1YTyy0T0JC85l1XiR65av9kdAnjp3s0</string>

	<key>BackendBaseURL</key>
	<string>https://pushup.weareo.fun</string>

	<!-- Google Sign-In iOS Client ID -->
	<key>GIDClientID</key>
	<string>932071108818-rooftfsunvngflbn61geqkdtpf0vk3gv.apps.googleusercontent.com</string>

	<!-- URL schemes for OAuth callbacks -->
	<!-- Apple Sign-In uses the bundle ID as the URL scheme automatically -->
	<!-- Google Sign-In redirect: reversed iOS client ID -->
	<key>CFBundleURLTypes</key>
	<array>
		<!-- App bundle URL scheme (used for Supabase OAuth redirect) -->
		<dict>
			<key>CFBundleURLName</key>
			<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
			</array>
		</dict>
		<!-- Custom deep-link scheme: pushup://
		     Handles pushup://friend-code/<CODE> and other in-app navigation.
		     When the app is installed, any link starting with pushup:// will
		     open the app directly. -->
		<dict>
			<key>CFBundleURLName</key>
			<string>com.flomks.pushup.deeplink</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>pushup</string>
			</array>
		</dict>
	</array>

	<!-- Background Modes: location updates for jogging GPS tracking.
	     Allows the app to continue receiving GPS updates while backgrounded
	     during an active jogging session. Required for accurate route tracking. -->
	<key>UIBackgroundModes</key>
	<array>
		<string>location</string>
		<string>remote-notification</string>
	</array>

	<!-- UILaunchStoryboardName is set via INFOPLIST_KEY_UILaunchStoryboardName
	     in the Xcode build settings (project.pbxproj) and merged into the
	     generated Info.plist at build time. Do NOT duplicate it here. -->
</dict>
</plist>
